msgid "Domain"
msgstr "ໂດເມນ"

#: avahi-ui/avahi-ui.c:190
msgid "The domain to browse in, or NULL for the default domain"
msgstr "ໂດເມນທີ່ຈະຄົ້ນຫາ ຫຼື NULL ສຳລັບໂດເມນເລີ່ມຕົ້ນ"

#: avahi-ui/avahi-ui.c:196
msgid "Service Type"
msgstr "ປະເພດການບໍລິການ"

#: avahi-ui/avahi-ui.c:196
msgid "The service type of the selected service"
msgstr "ປະເພດຂອງການບໍລິການທີ່ເລືອກ"

#: avahi-ui/avahi-ui.c:202 avahi-ui/avahi-ui.c:1035
msgid "Service Name"
msgstr "ຊື່ການບໍລິການ"

#: avahi-ui/avahi-ui.c:202
msgid "The service name of the selected service"
msgstr "ຊື່ຂອງການບໍລິການທີ່ເລືອກ"

#: avahi-ui/avahi-ui.c:208
msgid "Address"
msgstr "ທີ່ຢູ່"

#: avahi-ui/avahi-ui.c:208
msgid "The address of the resolved service"
msgstr "ທີ່ຢູ່ຂອງການບໍລິການທີ່ຄົ້ນຫາພົບ"

#: avahi-ui/avahi-ui.c:213
msgid "Port"
msgstr "ພອດ"

#: avahi-ui/avahi-ui.c:213
msgid "The IP port number of the resolved service"
msgstr "ເລກພອດ IP ຂອງການບໍລິການທີ່ຄົ້ນຫາພົບ"

#: avahi-ui/avahi-ui.c:219
msgid "Host Name"
msgstr "ຊື່ໂຮສ"

#: avahi-ui/avahi-ui.c:219
msgid "The host name of the resolved service"
msgstr "ຊື່ໂຮສຂອງການບໍລິການທີ່ຄົ້ນຫາພົບ"

#: avahi-ui/avahi-ui.c:225
msgid "TXT Data"
msgstr "ຂໍ້ມູນ TXT"

#: avahi-ui/avahi-ui.c:225
msgid "The TXT data of the resolved service"
msgstr "ຂໍ້ມູນ TXT ຂອງການບໍລິການທີ່ຄົ້ນຫາພົບ"

#: avahi-ui/avahi-ui.c:230
msgid "Resolve Service"
msgstr "ແກ້ໄຂຊື່ການບໍລິການ (Resolve)"

#: avahi-ui/avahi-ui.c:230
msgid "Resolve the selected service automatically before returning"
msgstr "ແກ້ໄຂຊື່ການບໍລິການທີ່ເລືອກໂດຍອັດຕະໂນມັດກ່ອນທີ່ຈະສົ່ງຄ່າກັບ"

#: avahi-ui/avahi-ui.c:236
msgid "Resolve Service Host Name"
msgstr "ແກ້ໄຂຊື່ໂຮສຂອງການບໍລິການ"

#: avahi-ui/avahi-ui.c:236
msgid ""
"Resolve the host name of the selected service automatically before returning"
msgstr "ແກ້ໄຂຊື່ໂຮສຂອງການບໍລິການທີ່ເລືອກໂດຍອັດຕະໂນມັດກ່ອນທີ່ຈະສົ່ງຄ່າກັບ"

#: avahi-ui/avahi-ui.c:242
msgid "Address family"
msgstr "ຕະກູນທີ່ຢູ່ (Address family)"

#: avahi-ui/avahi-ui.c:242
msgid "The address family for host name resolution"
msgstr "ຕະກູນທີ່ຢູ່ສຳລັບການແກ້ໄຂຊື່ໂຮສ"

#: avahi-ui/avahi-ui.c:326
#, c-format
msgid "Avahi client failure: %s"
msgstr "ຂໍ້ຜິດພາດຂອງໄຄເອັນ Avahi: %s"

#: avahi-ui/avahi-ui.c:388
#, c-format
msgid "Avahi resolver failure: %s"
msgstr "ຂໍ້ຜິດພາດຂອງຕົວແກ້ໄຂຊື່ Avahi: %s"

#: avahi-ui/avahi-ui.c:518
#, c-format
msgid "Browsing for service type %s in domain %s failed: %s"
msgstr "ການຄົ້ນຫາປະເພດການບໍລິການ %s ໃນໂດເມນ %s ລົ້ມເຫຼວ: %s"

#: avahi-ui/avahi-ui.c:519 avahi-utils/avahi-browse.c:168
#: avahi-utils/avahi-browse.c:169 avahi-utils/avahi-browse.c:178
#: avahi-utils/avahi-browse.c:179
msgid "n/a"
msgstr "ບໍ່ລະບຸ"

#: avahi-ui/avahi-ui.c:649
#, c-format
msgid "Avahi domain browser failure: %s"
msgstr "ຂໍ້ຜິດພາດຂອງຕົວຄົ້ນຫາໂດເມນ Avahi: %s"

#: avahi-ui/avahi-ui.c:684
#, c-format
msgid "Failed to read Avahi domain: %s"
msgstr "ອ່ານໂດເມນ Avahi ບໍ່ສຳເລັດ: %s"

#: avahi-ui/avahi-ui.c:706
msgid "Browse service type list is empty!"
msgstr "ລາຍການປະເພດການບໍລິການທີ່ຄົ້ນຫາວ່າງເປົ່າ!"

#: avahi-ui/avahi-ui.c:717
#, c-format
msgid "Failed to connect to Avahi server: %s"
msgstr "ເຊື່ອມຕໍ່ຫາເຊີບເວີ Avahi ບໍ່ສຳເລັດ: %s"

#: avahi-ui/avahi-ui.c:735
msgid "Browsing for services on <b>local network</b>:"
msgstr "ກຳລັງຄົ້ນຫາການບໍລິການໃນ <b>ເຄືອຂ່າຍທ້ອງຖິ່ນ</b>:"

#: avahi-ui/avahi-ui.c:737
#, c-format
msgid "Browsing for services in domain <b>%s</b>:"
msgstr "ກຳລັງຄົ້ນຫາການບໍລິການໃນໂດເມນ <b>%s</b>:"

#: avahi-ui/avahi-ui.c:773
#, c-format
msgid "Failed to create browser for %s: %s"
msgstr "ສ້າງຕົວຄົ້ນຫາສຳລັບ %s ບໍ່ສຳເລັດ: %s"

#: avahi-ui/avahi-ui.c:907
#, c-format
msgid "Failed to create resolver for %s of type %s in domain %s: %s"
msgstr "ສ້າງຕົວແກ້ໄຂຊື່ສຳລັບ %s ປະເພດ %s ໃນໂດເມນ %s ບໍ່ສຳເລັດ: %s"

#: avahi-ui/avahi-ui.c:982
#, c-format
msgid "Failed to create domain browser: %s"
msgstr "ສ້າງຕົວຄົ້ນຫາໂດເມນບໍ່ສຳເລັດ: %s"

