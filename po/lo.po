#: avahi-ui/avahi-ui.c:185
msgid "Browse Service Types"
msgstr "ຄົ້ນຫາປະເພດການບໍລິການ"

#: avahi-ui/avahi-ui.c:185
msgid "A NULL terminated list of service types to browse for"
msgstr "ລາຍການປະເພດການບໍລິການທີ່ລົງທ້າຍດ້ວຍ NULL ເພື່ອຄົ້ນຫາ"

