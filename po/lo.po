#: avahi-common/error.c:30
msgid "OK"
msgstr "ຕົກລົງ"

#: avahi-common/error.c:31
msgid "Operation failed"
msgstr "ການເຮັດວຽກຜິດພາດ"

#: avahi-common/error.c:32
msgid "Bad state"
msgstr "ສະຖານະບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:33
msgid "Invalid host name"
msgstr "ຊື່ໂຮສບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:34
msgid "Invalid domain name"
msgstr "ຊື່ໂດເມນບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:35
msgid "No suitable network protocol available"
msgstr "ບໍ່ມີໂປຣໂຕຄໍເຄືອຂ່າຍທີ່ເໝາະສົມ"

#: avahi-common/error.c:36
msgid "Invalid DNS TTL"
msgstr "ຄ່າ DNS TTL ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:37
msgid "Resource record key is pattern"
msgstr "ຄີບັນທຶກຊັບພະຍາກອນເປັນຮູບແບບ (Pattern)"

#: avahi-common/error.c:38
msgid "Local name collision"
msgstr "ຊື່ທ້ອງຖິ່ນຊໍ້າກັນ"

#: avahi-common/error.c:39
msgid "Invalid record"
msgstr "ບັນທຶກບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:41
msgid "Invalid service name"
msgstr "ຊື່ການບໍລິການບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:42
msgid "Invalid service type"
msgstr "ປະເພດການບໍລິການບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:43
msgid "Invalid port number"
msgstr "ເລກພອດບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:44
msgid "Invalid record key"
msgstr "ຄີບັນທຶກບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:45
msgid "Invalid address"
msgstr "ທີ່ຢູ່ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:46
msgid "Timeout reached"
msgstr "ເກີນກຳນົດເວລາ"

#: avahi-common/error.c:47
msgid "Too many clients"
msgstr "ຜູ້ໃຊ້ບໍລິການຫຼາຍເກີນໄປ"

#: avahi-common/error.c:48
msgid "Too many objects"
msgstr "ອອບເຈັກຫຼາຍເກີນໄປ"

#: avahi-common/error.c:49
msgid "Too many entries"
msgstr "ລາຍການຫຼາຍເກີນໄປ"

#: avahi-common/error.c:50
msgid "OS Error"
msgstr "ຂໍ້ຜິດພາດຂອງລະບົບປະຕິບັດການ"

#: avahi-common/error.c:52
msgid "Access denied"
msgstr "ຖືກປະຕິເສດການເຂົ້າເຖິງ"

#: avahi-common/error.c:53
msgid "Invalid operation"
msgstr "ການເຮັດວຽກບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:54
msgid "An unexpected D-Bus error occurred"
msgstr "ເກີດຂໍ້ຜິດພາດ D-Bus ທີ່ບໍ່ຄາດຄິດ"

#: avahi-common/error.c:55
msgid "Daemon connection failed"
msgstr "ການເຊື່ອມຕໍ່ເດມອນ (Daemon) ລົ້ມເຫຼວ"

#: avahi-common/error.c:56
msgid "Memory exhausted"
msgstr "ໜ່ວຍຄວາມຈຳເຕັມ"

#: avahi-common/error.c:57
msgid "The object passed in was not valid"
msgstr "ອອບເຈັກທີ່ສົ່ງມາບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:58
msgid "Daemon not running"
msgstr "ເດມອນ (Daemon) ບໍ່ໄດ້ເຮັດວຽກ"

#: avahi-common/error.c:59
msgid "Invalid interface index"
msgstr "ດັດສະນີອິນເຕີເຟສບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:60
msgid "Invalid protocol specification"
msgstr "ຂໍ້ກຳນົດໂປຣໂຕຄໍບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:61
msgid "Invalid flags"
msgstr "ແຟລັກ (Flags) ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:63
msgid "Not found"
msgstr "ບໍ່ພົບ"

#: avahi-common/error.c:64
msgid "Invalid configuration"
msgstr "ການກຳນົດຄ່າບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:65
msgid "Version mismatch"
msgstr "ເວີຊັນບໍ່ກົງກັນ"

#: avahi-common/error.c:66
msgid "Invalid service subtype"
msgstr "ປະເພດການບໍລິການຍ່ອຍບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:67
msgid "Invalid packet"
msgstr "ແພັກເກັດບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:68
msgid "Invalid DNS return code"
msgstr "ລະຫັດຕອບກັບ DNS ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:69
msgid "DNS failure: FORMERR"
msgstr "DNS ຜິດພາດ: FORMERR"

#: avahi-common/error.c:70
msgid "DNS failure: SERVFAIL"
msgstr "DNS ຜິດພາດ: SERVFAIL"

#: avahi-common/error.c:71
msgid "DNS failure: NXDOMAIN"
msgstr "DNS ຜິດພາດ: NXDOMAIN"

#: avahi-common/error.c:72
msgid "DNS failure: NOTIMP"
msgstr "DNS ຜິດພາດ: NOTIMP"

#: avahi-common/error.c:74
msgid "DNS failure: REFUSED"
msgstr "DNS ຜິດພາດ: REFUSED"

#: avahi-common/error.c:75
msgid "DNS failure: YXDOMAIN"
msgstr "DNS ຜິດພາດ: YXDOMAIN"

#: avahi-common/error.c:76
msgid "DNS failure: YXRRSET"
msgstr "DNS ຜິດພາດ: YXRRSET"

#: avahi-common/error.c:77
msgid "DNS failure: NXRRSET"
msgstr "DNS ຜິດພາດ: NXRRSET"

#: avahi-common/error.c:78
msgid "DNS failure: NOTAUTH"
msgstr "DNS ຜິດພາດ: NOTAUTH"

#: avahi-common/error.c:79
msgid "DNS failure: NOTZONE"
msgstr "DNS ຜິດພາດ: NOTZONE"

#: avahi-common/error.c:80
msgid "Invalid RDATA"
msgstr "RDATA ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:81
msgid "Invalid DNS type"
msgstr "ປະເພດ DNS ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:82
msgid "Invalid DNS class"
msgstr "ຄລາສ DNS ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:83
msgid "Not supported"
msgstr "ບໍ່ຮອງຮັບ"

#: avahi-common/error.c:85
msgid "Not permitted"
msgstr "ບໍ່ໄດ້ຮັບອະນຸຍາດ"

#: avahi-common/error.c:86
msgid "Invalid argument"
msgstr "ອາຄິວເມັນ (Argument) ບໍ່ຖືກຕ້ອງ"

#: avahi-common/error.c:87
msgid "Is empty"
msgstr "ວ່າງເປົ່າ"

#: avahi-common/error.c:88
msgid "The requested operation is invalid because redundant"
msgstr "ການເຮັດວຽກທີ່ຮ້ອງຂໍບໍ່ຖືກຕ້ອງເນື່ອງຈາກມີຄວາມຊໍ້າຊ້ອນ"

#: avahi-common/error.c:94
msgid "Invalid Error Code"
msgstr "ລະຫັດຂໍ້ຜິດພາດບໍ່ຖືກຕ້ອງ"

